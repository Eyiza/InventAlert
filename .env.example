# =============================================================================
# InventAlert — environment variables template
# Copy this file to .env and fill in all values before running the project.
# =============================================================================

# ── MySQL ─────────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=
MYSQL_DATABASE=inventalert_identity

MYSQL_IDENTITY_USER=root
MYSQL_IDENTITY_PASSWORD=

MYSQL_INVENTORY_USER=root
MYSQL_INVENTORY_PASSWORD=

# ── JWT ───────────────────────────────────────────────────────────────────────
# Must be identical across all three services. Minimum 32 characters.
# Generate: openssl rand -base64 48
JWT_SECRET=

# ── Super Admin ───────────────────────────────────────────────────────────────
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=
SUPER_ADMIN_ID=superadmin-fixed-uuid-0001

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USERNAME=
SMTP_PASSWORD=
MAIL_FROM=noreply@inventalert.com

# ── Notifications ─────────────────────────────────────────────────────────────
NOTIFICATION_TTL_DAYS=90

# ── ClickHouse (analytics) ────────────────────────────────────────────────────
CLICKHOUSE_PASSWORD=

# ── Google Maps (optional) ────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ── Frontend URL (used in emails, e.g. password reset link) ──────────────────
FRONTEND_URL=http://localhost:5173

# ── Frontend API base URL ─────────────────────────────────────────────────────
# Full Docker stack (docker compose --profile app up) — Nginx on port 80:
#   VITE_API_BASE_URL=http://localhost
# Local dev (./mvnw spring-boot:run) — services on individual ports:
#   Not needed; each slice points directly to its service port (see Step 4 notes)
VITE_API_BASE_URL=http://localhost
