{
  "info": {
    "name": "InventAlert — Identity Service",
    "description": "All endpoints for the IdentityService running on http://localhost:8081.\n\nWorkflow:\n1. Run 'Company Signup' → token and companyId are auto-saved.\n2. Run 'Login' to refresh the token.\n3. Use 'Create User' to add staff — warehouseId is now required for non-ADMIN roles and a warehouse assignment is auto-created.\n4. For SuperAdmin flows, run 'SuperAdmin Login' first.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",        "value": "http://localhost:8081" },
    { "key": "adminToken",     "value": "" },
    { "key": "superAdminToken","value": "" },
    { "key": "companyId",      "value": "" },
    { "key": "userId",         "value": "" },
    { "key": "userId2",        "value": "" },
    { "key": "warehouseId",    "value": "warehouse-uuid-001" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Company Signup",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('adminToken', body.token);",
                  "  pm.collectionVariables.set('companyId', body.companyId);",
                  "  pm.test('Returns 201 with token', () => pm.expect(body.token).to.not.be.empty);",
                  "  pm.test('Role is ADMIN', () => pm.expect(body.role).to.eql('ADMIN'));",
                  "  pm.test('companyId is set', () => pm.expect(body.companyId).to.not.be.empty);",
                  "  pm.test('No warehouseId for ADMIN', () => pm.expect(body.warehouseId).to.be.undefined);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"companyName\": \"Acme Corp\",\n  \"adminEmail\": \"admin@acme.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/signup", "host": ["{{baseUrl}}"], "path": ["api","auth","signup"] }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('adminToken', body.token);",
                  "  if (body.warehouseId) pm.collectionVariables.set('warehouseId', body.warehouseId);",
                  "  pm.test('Returns 200 with token', () => pm.expect(body.token).to.not.be.empty);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@acme.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api","auth","login"] }
          }
        },
        {
          "name": "Login — Wrong Password (expect 401)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Returns 401', () => pm.expect(pm.response.code).to.eql(401));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@acme.com\",\n  \"password\": \"wrongpassword\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api","auth","login"] }
          }
        },
        {
          "name": "SuperAdmin Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('superAdminToken', body.token);",
                  "  pm.test('Returns 200 with token', () => pm.expect(body.token).to.not.be.empty);",
                  "  pm.test('Role is SUPER_ADMIN', () => pm.expect(body.role).to.eql('SUPER_ADMIN'));",
                  "  pm.test('No companyId in response', () => pm.expect(body.companyId).to.be.undefined);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"superadmin@inventalert.io\",\n  \"password\": \"SuperSecure123!\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/superadmin/login", "host": ["{{baseUrl}}"], "path": ["api","auth","superadmin","login"] }
          }
        }
      ]
    },
    {
      "name": "Users (ADMIN)",
      "item": [
        {
          "name": "Create User — Manager",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('userId', body.id);",
                  "  pm.test('Returns 201', () => pm.expect(pm.response.code).to.eql(201));",
                  "  pm.test('Email matches', () => pm.expect(body.email).to.eql('manager@acme.com'));",
                  "  pm.test('Role is MANAGER', () => pm.expect(body.role).to.eql('MANAGER'));",
                  "  pm.test('isActive is true', () => pm.expect(body.isActive).to.be.true);",
                  "  pm.test('No warehouseId in UserResponse (use GET assignments)', () => pm.expect(body.warehouseId).to.be.undefined);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}" }] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"manager@acme.com\",\n  \"password\": \"password123\",\n  \"role\": \"MANAGER\",\n  \"warehouseId\": \"{{warehouseId}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/users", "host": ["{{baseUrl}}"], "path": ["api","users"] }
          }
        },
        {
          "name": "Create User — Procurement Officer",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('userId2', body.id);",
                  "  pm.test('Returns 201', () => pm.expect(pm.response.code).to.eql(201));",
                  "  pm.test('Role is PROCUREMENT_OFFICER', () => pm.expect(body.role).to.eql('PROCUREMENT_OFFICER'));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}" }] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"po@acme.com\",\n  \"password\": \"password123\",\n  \"role\": \"PROCUREMENT_OFFICER\",\n  \"warehouseId\": \"{{warehouseId}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/users", "host": ["{{baseUrl}}"], "path": ["api","users"] }
          }
        },
        {
          "name": "Create User — Duplicate Email (expect 409)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Returns 409', () => pm.expect(pm.response.code).to.eql(409));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}" }] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"manager@acme.com\",\n  \"password\": \"password123\",\n  \"role\": \"PROCUREMENT_OFFICER\",\n  \"warehouseId\": \"{{warehouseId}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/users", "host": ["{{baseUrl}}"], "path": ["api","users"] }
          }
        },
        {
          "name": "Create User — Missing warehouseId for non-ADMIN (expect 400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Returns 400', () => pm.expect(pm.response.code).to.eql(400));",
                  "pm.test('Error mentions warehouseId', () => pm.expect(pm.response.json().message).to.include('warehouseId'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}" }] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"nowarehouse@acme.com\",\n  \"password\": \"password123\",\n  \"role\": \"MANAGER\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/users", "host": ["{{baseUrl}}"], "path": ["api","users"] }
          }
        },
        {
          "name": "Create User — Duplicate Manager for Warehouse (expect 409)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Returns 409', () => pm.expect(pm.response.code).to.eql(409));",
                  "pm.test('Error mentions manager', () => pm.expect(pm.response.json().message).to.include('manager'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}" }] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"manager2@acme.com\",\n  \"password\": \"password123\",\n  \"role\": \"MANAGER\",\n  \"warehouseId\": \"{{warehouseId}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/users", "host": ["{{baseUrl}}"], "path": ["api","users"] }
          }
        },
        {
          "name": "Create User — Missing Role (expect 400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Returns 400', () => pm.expect(pm.response.code).to.eql(400));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}" }] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"bad@acme.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/users", "host": ["{{baseUrl}}"], "path": ["api","users"] }
          }
        },
        {
          "name": "List Users",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Returns 200', () => pm.expect(pm.response.code).to.eql(200));",
                  "pm.test('Response is array', () => pm.expect(pm.response.json()).to.be.an('array'));",
                  "pm.test('Users have no warehouseId field', () => {",
                  "  pm.response.json().forEach(u => pm.expect(u.warehouseId).to.be.undefined);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}" }] },
            "url": { "raw": "{{baseUrl}}/api/users", "host": ["{{baseUrl}}"], "path": ["api","users"] }
          }
        },
        {
          "name": "Update User Role",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Returns 200', () => pm.expect(pm.response.code).to.eql(200));",
                  "pm.test('Role updated', () => pm.expect(pm.response.json().role).to.eql('PROCUREMENT_OFFICER'));"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}" }] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"PROCUREMENT_OFFICER\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/users/{{userId}}/role", "host": ["{{baseUrl}}"], "path": ["api","users","{{userId}}","role"] }
          }
        },
        {
          "name": "Deactivate User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Returns 200', () => pm.expect(pm.response.code).to.eql(200));",
                  "pm.test('isActive is false', () => pm.expect(pm.response.json().isActive).to.be.false);"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}" }] },
            "url": { "raw": "{{baseUrl}}/api/users/{{userId}}/deactivate", "host": ["{{baseUrl}}"], "path": ["api","users","{{userId}}","deactivate"] }
          }
        },
        {
          "name": "Deactivate User — Already Inactive (expect 409)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Returns 409', () => pm.expect(pm.response.code).to.eql(409));"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}" }] },
            "url": { "raw": "{{baseUrl}}/api/users/{{userId}}/deactivate", "host": ["{{baseUrl}}"], "path": ["api","users","{{userId}}","deactivate"] }
          }
        },
        {
          "name": "Assign User to Additional Warehouse",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Returns 201', () => pm.expect(pm.response.code).to.eql(201));",
                  "pm.test('warehouseId matches', () => pm.expect(pm.response.json().warehouseId).to.eql('warehouse-uuid-002'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}" }] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"warehouseId\": \"warehouse-uuid-002\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/users/{{userId2}}/assign", "host": ["{{baseUrl}}"], "path": ["api","users","{{userId2}}","assign"] }
          }
        },
        {
          "name": "Assign Manager to Already-Managed Warehouse (expect 409)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Returns 409', () => pm.expect(pm.response.code).to.eql(409));",
                  "pm.test('Error mentions manager', () => pm.expect(pm.response.json().message).to.include('manager'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}" }] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"warehouseId\": \"{{warehouseId}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/users/{{userId2}}/assign", "host": ["{{baseUrl}}"], "path": ["api","users","{{userId2}}","assign"] }
          }
        },
        {
          "name": "Get User Assignments",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Returns 200', () => pm.expect(pm.response.code).to.eql(200));",
                  "pm.test('Response is array', () => pm.expect(pm.response.json()).to.be.an('array'));",
                  "pm.test('At least one assignment', () => pm.expect(pm.response.json().length).to.be.at.least(1));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}" }] },
            "url": { "raw": "{{baseUrl}}/api/users/{{userId}}/assignments", "host": ["{{baseUrl}}"], "path": ["api","users","{{userId}}","assignments"] }
          }
