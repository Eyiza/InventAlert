{
  "annotations": {"list": []},
  "description": "InventAlert Services — HTTP, JVM, and Kafka metrics",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "title": "HTTP",
      "type": "row",
      "id": 10,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0}
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2, "fillOpacity": 10},
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 1},
      "id": 1,
      "options": {"tooltip": {"mode": "multi"}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum(rate(http_server_requests_seconds_count{application=~\"$service\"}[2m])) by (application)",
          "legendFormat": "{{application}}"
        }
      ],
      "title": "Request Rate",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2, "fillOpacity": 10},
          "unit": "reqps"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 1},
      "id": 2,
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum(rate(http_server_requests_seconds_count{application=~\"$service\",status=~\"5..\"}[2m])) by (application)",
          "legendFormat": "{{application}} 5xx"
        }
      ],
      "title": "Error Rate (5xx)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2},
          "unit": "s"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 9},
      "id": 3,
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{application=~\"$service\"}[2m])) by (application, le))",
          "legendFormat": "{{application}} p99"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{application=~\"$service\"}[2m])) by (application, le))",
          "legendFormat": "{{application}} p95"
        }
      ],
      "title": "Response Latency (p95 / p99)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2},
          "unit": "short"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 9},
      "id": 11,
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "tomcat_threads_busy_threads{application=~\"$service\"}",
          "legendFormat": "{{application}} busy"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "tomcat_threads_config_max_threads{application=~\"$service\"}",
          "legendFormat": "{{application}} max"
        }
      ],
      "title": "Tomcat Threads",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "title": "JVM",
      "type": "row",
      "id": 20,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 17}
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {"unit": "bytes", "color": {"mode": "palette-classic"}}
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 18},
      "id": 4,
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "jvm_memory_used_bytes{application=~\"$service\",area=\"heap\"}",
          "legendFormat": "{{application}} heap used"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "jvm_memory_max_bytes{application=~\"$service\",area=\"heap\"}",
          "legendFormat": "{{application}} heap max"
        }
      ],
      "title": "JVM Heap Memory",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {"unit": "percentunit", "min": 0, "max": 1, "color": {"mode": "palette-classic"}}
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 18},
      "id": 5,
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "process_cpu_usage{application=~\"$service\"}",
          "legendFormat": "{{application}}"
        }
      ],
      "title": "CPU Usage",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {"unit": "s", "color": {"mode": "palette-classic"}}
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 26},
      "id": 6,
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "rate(jvm_gc_pause_seconds_sum{application=~\"$service\"}[2m]) / rate(jvm_gc_pause_seconds_count{application=~\"$service\"}[2m])",
          "legendFormat": "{{application}} {{action}}"
        }
      ],
      "title": "GC Pause Time (avg)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {"unit": "short", "color": {"mode": "palette-classic"}}
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 26},
      "id": 7,
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "jvm_threads_live_threads{application=~\"$service\"}",
          "legendFormat": "{{application}} live"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "jvm_threads_daemon_threads{application=~\"$service\"}",
          "legendFormat": "{{application}} daemon"
        }
      ],
      "title": "JVM Threads",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "title": "Kafka",
      "type": "row",
      "id": 30,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 34}
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {"unit": "short", "color": {"mode": "palette-classic"}}
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 35},
      "id": 8,
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "kafka_consumer_fetch_manager_records_consumed_rate{application=~\"$service\"}",
          "legendFormat": "{{application}} {{topic}}"
        }
      ],
      "title": "Kafka Records Consumed / sec",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {"unit": "short", "color": {"mode": "palette-classic"}}
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 35},
      "id": 9,
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "kafka_producer_record_send_rate{application=~\"$service\"}",
          "legendFormat": "{{application}} {{topic}}"
        }
      ],
      "title": "Kafka Records Produced / sec",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["inventalert"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource",
        "label": "Data Source"
      },
      {
        "current": {"selected": true, "text": "All", "value": "$__all"},
        "datasource": {"type": "prometheus", "uid": "${datasource}"},
        "definition": "label_values(jvm_memory_used_bytes, application)",
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "name": "service",
        "query": {"query": "label_values(jvm_memory_used_bytes, application)", "refId": "A"},
        "refresh": 2,
        "type": "query",
        "label": "Service"
      }
    ]
  },
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "title": "InventAlert Services",
  "uid": "inventalert-overview",
  "version": 1
}
