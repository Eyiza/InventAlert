{
  "info": {
    "name": "InventAlert — Analytics Service",
    "description": "All endpoints for the AnalyticsService running on http://localhost:8084.\n\nAll analytics endpoints are read-only — data enters ClickHouse via Kafka, not through this API.\n\nWorkflow:\n1. Log in via the Identity Service (port 8081) and paste the returned token into the 'token' collection variable.\n2. The token's role determines what you can see:\n   - ADMIN / MANAGER   : stock, alert, transfer, notification analytics\n   - PROCUREMENT_OFFICER: alert analytics only\n   - SUPER_ADMIN        : company onboarding analytics only\n3. All date params accept ISO-8601 instants, e.g. 2025-01-01T00:00:00Z\n   Omit 'from' and 'to' to default to the last 30 days.\n\nAll endpoints require a Bearer JWT token.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8084" },
    { "key": "token",   "value": "" },
    { "key": "from",    "value": "2025-01-01T00:00:00Z" },
    { "key": "to",      "value": "2025-12-31T23:59:59Z" }
  ],
  "item": [
    {
      "name": "Stock Analytics",
      "item": [
        {
          "name": "Stock Summary (last 30 days)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Returns 200', () => pm.expect(pm.response.code).to.eql(200));",
                  "pm.test('Has expected fields', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('totalIntake');",
                  "  pm.expect(body).to.have.property('totalOutbound');",
                  "  pm.expect(body).to.have.property('netChange');",
                  "  pm.expect(body.totalIntake).to.be.a('number').and.at.least(0);",
                  "  pm.expect(body.totalOutbound).to.be.a('number').and.at.least(0);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "url": {
              "raw": "{{baseUrl}}/api/analytics/stock/summary",
              "host": ["{{baseUrl}}"],
              "path": ["api", "analytics", "stock", "summary"]
            }
          }
        },
        {
          "name": "Stock Summary (custom date range)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Returns 200', () => pm.expect(pm.response.code).to.eql(200));",
                  "pm.test('Has summary fields', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('totalIntake');",
                  "  pm.expect(body).to.have.property('totalOutbound');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "url": {
              "raw": "{{baseUrl}}/api/analytics/stock/summary?from={{from}}&to={{to}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "analytics", "stock", "summary"],
              "query": [
                { "key": "from", "value": "{{from}}" },
                { "key": "to",   "value": "{{to}}" }
              ]
            }
          }
        },
        {
          "name": "Top Moving Products (outbound, top 10)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Returns 200', () => pm.expect(pm.response.code).to.eql(200));",
                  "pm.test('Response is array', () => pm.expect(pm.response.json()).to.be.an('array'));",
                  "pm.test('At most 10 results', () => pm.expect(pm.response.json().length).to.be.at.most(10));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "url": {
              "raw": "{{baseUrl}}/api/analytics/stock/top-products?type=OUTBOUND_SALE&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "analytics", "stock", "top-products"],
              "query": [
                { "key": "type",  "value": "OUTBOUND_SALE" },
                { "key": "limit", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Top Moving Products (intake, top 5)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Returns 200', () => pm.expect(pm.response.code).to.eql(200));",
                  "pm.test('Response is array', () => pm.expect(pm.response.json()).to.be.an('array'));",
                  "pm.test('At most 5 results', () => pm.expect(pm.response.json().length).to.be.at.most(5));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "url": {
              "raw": "{{baseUrl}}/api/analytics/stock/top-products?type=INTAKE&limit=5",
              "host": ["{{baseUrl}}"],
              "path": ["api", "analytics", "stock", "top-products"],
              "query": [
                { "key": "type",  "value": "INTAKE" },
                { "key": "limit", "value": "5" }
              ]
            }
          }
        },
        {
          "name": "Daily Movement Trend",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Returns 200', () => pm.expect(pm.response.code).to.eql(200));",
                  "pm.test('Response is array', () => pm.expect(pm.response.json()).to.be.an('array'));",
                  "if (pm.response.json().length > 0) {",
                  "  pm.test('Each row has date and quantity fields', () => {",
                  "    const row = pm.response.json()[0];",
                  "    pm.expect(row).to.have.property('date');",
                  "  });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "url": {
              "raw": "{{baseUrl}}/api/analytics/stock/movements/trend?from={{from}}&to={{to}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "analytics", "stock", "movements", "trend"],
              "query": [
                { "key": "from", "value": "{{from}}" },
                { "key": "to",   "value": "{{to}}" }
              ]
            }
          }
        },
        {
          "name": "Movement Breakdown by Warehouse",
