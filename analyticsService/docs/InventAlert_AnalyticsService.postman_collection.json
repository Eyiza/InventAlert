                  "pm.test('Response is array', () => pm.expect(pm.response.json()).to.be.an('array'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "url": {
              "raw": "{{baseUrl}}/api/analytics/stock/movements/by-warehouse?from={{from}}&to={{to}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "analytics", "stock", "movements", "by-warehouse"],
              "query": [
                { "key": "from", "value": "{{from}}" },
                { "key": "to",   "value": "{{to}}" }
              ]
            }
          }
        }
      ]
    },
