    {
      "name": "Movements",
      "item": [
        {
          "name": "Record Intake",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  pm.test('Returns 201', () => pm.expect(pm.response.code).to.eql(201));",
                  "  pm.test('type is INTAKE', () => pm.expect(body.type).to.eql('INTAKE'));",
                  "  pm.test('quantity matches', () => pm.expect(body.quantity).to.eql(200));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{staffToken}}" }] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"{{productId}}\",\n  \"warehouseId\": \"{{warehouseId}}\",\n  \"type\": \"INTAKE\",\n  \"quantity\": 200,\n  \"referenceNumber\": \"PO-2026-001\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/movements", "host": ["{{baseUrl}}"], "path": ["api","movements"] }
          }
        },
