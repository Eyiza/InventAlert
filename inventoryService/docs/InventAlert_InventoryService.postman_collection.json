                  "pm.test('Returns 400', () => pm.expect(pm.response.code).to.eql(400));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{staffToken}}" }] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"{{productId}}\",\n  \"warehouseId\": \"{{warehouseId}}\",\n  \"type\": \"INTAKE\",\n  \"quantity\": 0\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/movements", "host": ["{{baseUrl}}"], "path": ["api","movements"] }
          }
