{
  "info": {
    "name": "InventAlert — Inventory Service",
    "description": "All endpoints for the InventoryService running on http://localhost:8082.\n\nWorkflow:\n1. Login via the Identity Service (http://localhost:8081) to get a JWT — paste it into the 'adminToken' variable.\n2. Run 'Create Warehouse' → warehouseId is auto-saved.\n3. Run 'Create Product' → productId is auto-saved.\n4. Record movements (use a WAREHOUSE_STAFF token for 'staffToken').\n5. Check stock, trigger alerts, test transfers and reconciliations.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",          "value": "http://localhost:8082" },
    { "key": "adminToken",       "value": "" },
    { "key": "managerToken",     "value": "" },
    { "key": "staffToken",       "value": "" },
    { "key": "procurementToken", "value": "" },
    { "key": "warehouseId",      "value": "" },
    { "key": "warehouseId2",     "value": "" },
    { "key": "productId",        "value": "" },
    { "key": "transferId",       "value": "" },
    { "key": "reconciliationId", "value": "" },
    { "key": "alertId",          "value": "" }
  ],
  "item": [

    {
      "name": "Warehouses",
      "item": [
        {
          "name": "Create Warehouse",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('warehouseId', body.id);",
                  "  pm.test('Returns 201', () => pm.expect(pm.response.code).to.eql(201));",
                  "  pm.test('id is set', () => pm.expect(body.id).to.not.be.empty);",
                  "  pm.test('isActive is true', () => pm.expect(body.isActive).to.be.true);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}" }] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Lagos Central\",\n  \"address\": \"14 Broad Street, Lagos Island\",\n  \"latitude\": 6.4550,\n  \"longitude\": 3.3841\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/warehouses", "host": ["{{baseUrl}}"], "path": ["api","warehouses"] }
          }
        },
        {
          "name": "Create Warehouse 2 (for transfer tests)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('warehouseId2', body.id);",
                  "  pm.test('Returns 201', () => pm.expect(pm.response.code).to.eql(201));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}" }] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Abuja North\",\n  \"address\": \"Plot 5 Wuse Zone 2, Abuja\",\n  \"latitude\": 9.0765,\n  \"longitude\": 7.3986\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/warehouses", "host": ["{{baseUrl}}"], "path": ["api","warehouses"] }
          }
        },
        {
          "name": "Create Warehouse — Missing Latitude (expect 400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Returns 400', () => pm.expect(pm.response.code).to.eql(400));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}" }] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Bad Warehouse\",\n  \"address\": \"Somewhere\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/warehouses", "host": ["{{baseUrl}}"], "path": ["api","warehouses"] }
          }
        },
        {
          "name": "List Warehouses",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Returns 200', () => pm.expect(pm.response.code).to.eql(200));",
                  "pm.test('Response is array', () => pm.expect(pm.response.json()).to.be.an('array'));",
                  "pm.test('At least one warehouse', () => pm.expect(pm.response.json().length).to.be.at.least(1));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}" }] },
            "url": { "raw": "{{baseUrl}}/api/warehouses", "host": ["{{baseUrl}}"], "path": ["api","warehouses"] }
          }
        },
        {
          "name": "Update Warehouse",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Returns 200', () => pm.expect(pm.response.code).to.eql(200));",
                  "pm.test('Name updated', () => pm.expect(pm.response.json().name).to.eql('Lagos Central (Updated)'));"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}" }] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Lagos Central (Updated)\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/warehouses/{{warehouseId}}", "host": ["{{baseUrl}}"], "path": ["api","warehouses","{{warehouseId}}"] }
          }
        },
        {
          "name": "Deactivate Warehouse",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Returns 204', () => pm.expect(pm.response.code).to.eql(204));"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}" }] },
            "url": { "raw": "{{baseUrl}}/api/warehouses/{{warehouseId}}/deactivate", "host": ["{{baseUrl}}"], "path": ["api","warehouses","{{warehouseId}}","deactivate"] }
          }
        }
      ]
    },

